# Copy file này thành .env và điền giá trị thực

# Tài khoản đăng nhập — có thể thêm nhiều user: "user1:pass1,user2:pass2"
USERS=admin:your_password_here

# Hoặc dùng tên biến riêng cho 1 user
# ADMIN_USER=admin
# ADMIN_PASS=your_password_here

# Chuỗi bí mật để mã hóa session (đổi thành chuỗi ngẫu nhiên dài)
SESSION_SECRET=change-this-to-a-long-random-string

# Môi trường (Railway tự set = production)
NODE_ENV=production
