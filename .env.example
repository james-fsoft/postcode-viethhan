# Copy file này thành .env và điền giá trị thực

# Tài khoản đăng nhập — có thể thêm nhiều user: "user1:pass1,user2:pass2"
USERS=admin:your_password_here

# Juso API Key (lấy miễn phí tại juso.go.kr)
# Nếu set biến này thì người dùng không cần nhập key trong UI
JUSO_API_KEY=your_juso_key_here

# Chuỗi bí mật để mã hóa JWT (đổi thành chuỗi ngẫu nhiên dài)
SESSION_SECRET=change-this-to-a-long-random-string

# Gói dịch vụ cho từng user: "user1:pro,company2:enterprise"
# Các gói: trial (15 lượt, 30 địa chỉ/lượt) | pro | enterprise (không giới hạn lượt)
# User không khai báo ở đây → mặc định trial. Để nâng cấp admin: USER_PLANS=admin:pro
USER_PLANS=

# Thông tin liên hệ hiện ở modal khi khách hết lượt dùng thử
CONTACT_INFO=support@transflash.app

# Môi trường (Vercel/Railway tự set = production)
NODE_ENV=production
